ENVIRONMENT=development
PORT=8080
LOG_LEVEL=debug

DATABASE_URL=postgres://postgres:postgres@localhost:5432/leadscraper?sslmode=disable
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=2
AUTO_MIGRATE=true

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-this-in-production
JWT_EXPIRATION=24h

# Leave API_KEY empty and the API is unauthenticated. Fine on localhost,
# not anywhere else.
API_KEY=

# ---- AI audit (optional) ----
# none | gemini | openai. Leaving it off means leads are scored by rules alone,
# which works perfectly well; the AI pass only adds the written critique.
#
# Do NOT point this at the local Ollama on the Athlon box: 2 cores and no usable
# GPU means minutes per lead. Gemini's free tier is far faster for this workload.
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=gemini-2.0-flash
AI_MAX_HTML_CHARS=12000

# For any OpenAI-compatible endpoint (Ollama, OpenRouter, vLLM):
#   AI_PROVIDER=openai
#   AI_BASE_URL=http://localhost:11434/v1
AI_BASE_URL=

# ---- Sources ----

# google_maps scrapes Google Maps directly via gosom/google-maps-scraper.
# NO API KEY NEEDED. This is the source that produces real leads.
GMAPS_ENABLED=true

# docker (uses the published image, which bundles Chromium) or binary (a
# google-maps-scraper already on your PATH).
GMAPS_MODE=docker

# NOTE the -rod tag. Do NOT use :latest. Every Playwright-based tag of this image
# is currently broken: they pin a driver version that only ever existed on
# playwright.azureedge.net, which Microsoft has retired, so the container dies on
# startup with "could not install driver ... 404". The -rod build drives Chromium
# over CDP with go-rod, downloads no driver, and works.
GMAPS_DOCKER_IMAGE=gosom/google-maps-scraper:latest-rod
GMAPS_BINARY=google-maps-scraper

# Each unit of concurrency is a whole headless Chromium. gosom's own Kubernetes
# example asks for 512Mi per instance, so on the 2-core / 7GB Athlon leave this
# at 1 and close your browser while a scrape runs. Raising it is the fastest way
# to push that machine into swap.
GMAPS_CONCURRENCY=1

# How far the Maps results list is scrolled. Each level is roughly another page
# of businesses and a lot more browser work. 2 is a sane starting point.
GMAPS_DEPTH=2
GMAPS_LANG=en

# gosom waits for more work instead of exiting, so this is what makes it stop.
GMAPS_EXIT_ON_INACTIVITY=2m
# Hard ceiling on one scrape. Browser-driven crawling is slow on a small box.
GMAPS_TIMEOUT=20m

# gosom can also visit each business's site to pull emails. Our own crawler
# already does that, and it roughly doubles the scrape time, so leave it off.
GMAPS_EXTRACT_EMAIL=false

# Optional alternative: the official, paid Places API, registered as the
# separate source "google_places". Not needed if you are using google_maps.
GOOGLE_PLACES_API_KEY=

CSV_IMPORT_DIR=data

# ---- Crawler ----
CRAWLER_MAX_PAGES=5
CRAWLER_TIMEOUT=15s
CRAWLER_DELAY=1s
CRAWLER_RESPECT_ROBOTS=true
# Raw HTML is by far the largest column in the schema. Only turn this on if you
# want to re-run extraction without re-crawling.
CRAWLER_STORE_HTML=false

# ---- Worker ----
# The crawl/score work is network-bound rather than CPU-bound, so 4 is fine even
# on two cores.
WORKER_CONCURRENCY=4
WORKER_JOB_TIMEOUT=2m
# A collection job drives a headless browser over Maps for minutes on end, so it
# gets its own, much longer budget. The 2m job timeout would kill every scrape
# before it produced a single row.
WORKER_COLLECT_TIMEOUT=30m
